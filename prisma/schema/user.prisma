model User {
  id           String   @id @default(uuid())
  email        String   @unique
  tokenVersion Int      @map("token_version")
  passwordHash String   @map("password_hash")
  name         String
  phone        String?  @unique
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens        RefreshToken[]
  platformAdminProfile PlatformAdminProfile?
  companyAdminProfile  CompanyAdminProfile?
  dispatcherProfile    DispatcherProfile?
  technicianProfile    TechnicianProfile?
  customerProfile      CustomerProfile?
  notifications        Notification[]
  auditLogs            AuditLog[]
  chatMessages         ChatMessage[]
  leadsDispatched      Lead[]                @relation("LeadDispatcher")
  ticketsCreated       Ticket[]              @relation("TicketCreatedBy")
  ticketsOwned         Ticket[]              @relation("TicketAssignedTo")

  @@index([role])
  @@index([isActive])
  @@map("users")
}
